	(bus_alias "Address[0..11]"
		(members "A0" "A1" "A2" "A3" "A4" "A5" "A6" "A7" "A8" "A9" "A10" "A11")
	)
	(bus_alias "Data[0..7]"
		(members "D0" "D1" "D2" "D3" "D4" "D5" "D6" "D7")
	)
	(bus_alias "ROM_offset[12..15]"
		(members "R13" "R14" "R15" "R12")
	)
	(text "If either one of the inputs is low, the output of the rom is enabled.\nXNOR is the right gate to use here, but the case when both inputs are 0\ncan be ignored, due to the fact that both the char rom and kernal/basic rom\nwill never be both selected simultaneously.\n"
		(exclude_from_sim no)
		(at 193.294 175.768 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "00fe0a9f-9a69-4299-90c7-5f94f9eaa131")
	)
	(text "J2 interfaces with U5 socket\nto monitor its CS pin"
		(exclude_from_sim no)
		(at 223.012 21.59 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "18732c41-49df-404f-95f3-f5de663892b9")
	)
	(text "The output of the OR gate is 0 only when both inputs are 0.\nTherefore, only when both ~{CS_{basic|kernal}} and ~{B}/K are low,\nthe conditions for selecting the BASIC rom are in place."
		(exclude_from_sim no)
		(at 46.99 219.202 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "19d0abd9-6047-4243-bb03-2b14842a938d")
	)
	(text "~{BASIC} is low when the C64 expects the BASIC rom"
		(exclude_from_sim no)
		(at 101.854 224.028 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "27c226a8-8668-4c7a-9954-cdbc1f6e4d61")
	)
	(text "If ~{BASIC} is pulled low, A13-15 on the ROM are forced low,\nregardless of whatever combination of K0-2 is chosen, thus\npresenting the basic rom on the data bus."
		(exclude_from_sim no)
		(at 88.138 189.738 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "5cadbe2a-07a0-4caf-9c98-82ca50ca144a")
	)
	(text "Use 74HCT parts instead of 74LS for U2, U3 & U4"
		(exclude_from_sim no)
		(at 296.164 107.95 0)
		(effects
			(font
				(size 5.08 5.08)
			)
		)
		(uuid "60336ba4-fd0c-428c-ad8f-1f8a9241c2e3")
	)
	(text "A '157 would very likely work instead"
		(exclude_from_sim no)
		(at 54.102 118.364 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "67e5eaa9-a567-4f55-86e3-78097d233633")
	)
	(text "Low for 0"
		(exclude_from_sim no)
		(at 30.988 174.498 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "9d20ba37-47bd-46eb-9750-a402f57dc024")
	)
	(text "J1 is a 28pin header that \nwill interface with U4 socket"
		(exclude_from_sim no)
		(at 178.562 41.402 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "b971a45c-952a-4c0f-8482-16d30e5ad8f0")
	)
	(text "The multiplexer transfers forward either the font selection, or the\nkernal selection, depending on the CS state"
		(exclude_from_sim no)
		(at 79.248 124.46 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "be72a569-741b-4d5f-bea1-8c7109bb9374")
	)
